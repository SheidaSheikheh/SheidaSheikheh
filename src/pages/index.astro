---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';

// Drifting H2 molecules (two bonded atoms) — the hydrogen motif.
const molecules = [
  { top: '16%', left: '12%', size: 50, op: 0.16, dur: 12, delay: 0 },
  { top: '68%', left: '16%', size: 36, op: 0.13, dur: 9, delay: 1.4 },
  { top: '28%', left: '83%', size: 56, op: 0.15, dur: 14, delay: 0.7 },
  { top: '74%', left: '78%', size: 42, op: 0.12, dur: 11, delay: 2.1 },
  { top: '50%', left: '92%', size: 28, op: 0.1, dur: 8, delay: 3 },
  { top: '10%', left: '62%', size: 30, op: 0.1, dur: 13, delay: 1 },
  { top: '86%', left: '46%', size: 26, op: 0.09, dur: 10, delay: 2.6 },
];
---

<BaseLayout fullscreen={true}>
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
      {
        molecules.map((m) => (
          <span
            class="mol"
            style={`top:${m.top};left:${m.left};width:${m.size}px;opacity:${m.op};animation-duration:${m.dur}s;animation-delay:${m.delay}s`}
          >
            <svg viewBox="0 0 40 24" fill="none">
              <line x1="13" y1="12" x2="27" y2="12" stroke="currentColor" stroke-width="2.5" />
              <circle cx="13" cy="12" r="7" fill="currentColor" />
              <circle cx="27" cy="12" r="7" fill="currentColor" />
            </svg>
          </span>
        ))
      }
    </div>

    <div class="hero-inner">
      <p class="eyebrow hero-eyebrow">{profile.affiliation} · Energy &amp; Petroleum Engineering</p>
      <h1 class="hero-name">{profile.name}</h1>
      <p class="hero-tagline">{profile.tagline}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding-inline: var(--pad);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80vw;
    height: 80vw;
    max-width: 760px;
    max-height: 760px;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--accent) 16%, transparent),
      transparent 60%
    );
    pointer-events: none;
  }
  .mol {
    position: absolute;
    color: var(--accent);
    animation-name: float;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    will-change: transform;
  }
  .mol svg {
    width: 100%;
    height: auto;
    display: block;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50% { transform: translateY(-16px) rotate(7deg); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    margin-inline: auto;
    padding-block: 2rem;
  }
  .hero-eyebrow {
    margin-bottom: 1.2rem;
  }
  .hero-name {
    font-size: clamp(2.9rem, 10vw, 6.5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
  }
  .hero-tagline {
    margin: 1.4rem auto 0;
    max-width: 40ch;
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    line-height: 1.5;
    color: var(--fg-muted);
    text-wrap: balance;
  }
</style>
