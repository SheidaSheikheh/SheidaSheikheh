---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';

// A single ellipse, drawn three times (rotated) to form the atom's orbits.
const ORBIT = 'M38,300 A262,96 0 1 0 562,300 A262,96 0 1 0 38,300 Z';
---

<BaseLayout fullscreen={true}>
  <section class="hero">
    <div class="atom-wrap" aria-hidden="true">
      <svg class="atom" viewBox="0 0 600 600" aria-hidden="true">
        <defs>
          <filter id="atomGlow" x="-60%" y="-60%" width="220%" height="220%">
            <feGaussianBlur stdDeviation="5" result="b" />
            <feMerge>
              <feMergeNode in="b" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
          <radialGradient id="atomCore">
            <stop offset="0%" class="core-in" />
            <stop offset="100%" class="core-out" />
          </radialGradient>
        </defs>

        <circle cx="300" cy="300" r="170" fill="url(#atomCore)" />

        <g class="atom-spin">
          <g transform="rotate(0 300 300)">
            <path id="o1" class="atom-orbit" d={ORBIT} />
            <circle class="atom-electron" r="6.5" filter="url(#atomGlow)">
              <animateMotion dur="7s" repeatCount="indefinite"><mpath href="#o1" /></animateMotion>
            </circle>
          </g>
          <g transform="rotate(60 300 300)">
            <path id="o2" class="atom-orbit" d={ORBIT} />
            <circle class="atom-electron" r="5.5" filter="url(#atomGlow)">
              <animateMotion dur="9.5s" begin="-3s" repeatCount="indefinite"><mpath href="#o2" /></animateMotion>
            </circle>
          </g>
          <g transform="rotate(120 300 300)">
            <path id="o3" class="atom-orbit" d={ORBIT} />
            <circle class="atom-electron" r="6" filter="url(#atomGlow)">
              <animateMotion dur="11s" begin="-6s" repeatCount="indefinite"><mpath href="#o3" /></animateMotion>
            </circle>
          </g>
        </g>

        <circle class="atom-nucleus" cx="300" cy="300" r="14" filter="url(#atomGlow)">
          <animate attributeName="r" values="13;16;13" dur="3.6s" repeatCount="indefinite" />
        </circle>
      </svg>
    </div>

    <div class="hero-inner">
      <p class="eyebrow hero-eyebrow">{profile.affiliation} · Energy &amp; Petroleum Engineering</p>
      <h1 class="hero-name">{profile.name}</h1>
      <p class="hero-tagline">{profile.tagline}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding-inline: var(--pad);
  }

  .atom-wrap {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    z-index: 0;
    pointer-events: none;
  }
  .atom {
    width: min(96vmin, 920px);
    height: auto;
    overflow: visible;
    animation: atom-rotate 120s linear infinite;
  }
  @keyframes atom-rotate {
    to { transform: rotate(360deg); }
  }
  .atom-orbit {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1.6;
    opacity: 0.26;
  }
  .atom-electron { fill: var(--accent); }
  .atom-nucleus { fill: var(--accent-strong); }
  .core-in { stop-color: var(--accent); stop-opacity: 0.28; }
  .core-out { stop-color: var(--accent); stop-opacity: 0; }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    margin-inline: auto;
    padding-block: 2rem;
  }
  .hero-eyebrow {
    margin-bottom: 1.2rem;
  }
  .hero-name {
    font-size: clamp(2.6rem, 9.5vw, 6.5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
  }
  .hero-tagline {
    margin: 1.4rem auto 0;
    max-width: 40ch;
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    line-height: 1.5;
    color: var(--fg-muted);
    text-wrap: balance;
  }
</style>

<script>
  // Respect reduced-motion: freeze the SMIL orbit timeline.
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll<SVGSVGElement>('svg.atom').forEach((el) => {
      try {
        el.pauseAnimations();
      } catch {
        /* no-op */
      }
    });
  }
</script>
