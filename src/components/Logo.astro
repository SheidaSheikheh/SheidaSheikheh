---
interface Props {
  size?: number;
  class?: string;
  title?: string;
}
const { size = 32, class: className = '', title = 'Sheida Sheikheh' } = Astro.props;
// Unique gradient/clip ids so multiple logos on a page don't collide.
const uid = 'lg-' + Math.random().toString(36).slice(2, 8);
---

<svg
  class:list={['logo', className]}
  width={size}
  height={size}
  viewBox="0 0 64 64"
  role="img"
  aria-label={title}
>
  <defs>
    <linearGradient id={`${uid}-g`} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0e7490"></stop>
      <stop offset="1" stop-color="#0b5566"></stop>
    </linearGradient>
    <clipPath id={`${uid}-c`}><rect width="64" height="64" rx="14"></rect></clipPath>
  </defs>
  <g clip-path={`url(#${uid}-c)`}>
    <rect width="64" height="64" fill={`url(#${uid}-g)`}></rect>
    <path d="M0,16 C18,11 33,19 48,15 C56,13 60,17 64,15 L64,64 L0,64 Z" fill="#ffffff" opacity="0.14"></path>
    <path d="M0,28 C16,24 34,31 50,27 C57,25 61,29 64,27 L64,64 L0,64 Z" fill="#ffffff" opacity="0.12"></path>
    <path d="M0,44 C20,40 36,46 52,43 C58,42 62,45 64,44 L64,64 L0,64 Z" fill="#ffffff" opacity="0.10"></path>
    <path d="M32 22c6.6 0 10.4 4.9 10.4 11.4 0 7.3-4.9 13-10.4 13s-10.4-5.7-10.4-13C21.6 26.9 25.4 22 32 22z" fill="#ffffff" opacity="0.96"></path>
    <circle cx="28.6" cy="34.6" r="3" fill="#0e7490"></circle>
    <circle cx="35.4" cy="38.4" r="2.2" fill="#0e7490"></circle>
    <circle cx="32" cy="29.6" r="1.6" fill="#0e7490"></circle>
  </g>
</svg>

<style>
  .logo {
    display: block;
    border-radius: 8px;
    flex: none;
  }
</style>
