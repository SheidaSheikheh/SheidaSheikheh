---
interface Props {
  caption?: string;
  /** let an interactive figure span wider than the prose column */
  wide?: boolean;
}
const { caption, wide = false } = Astro.props;
---

<figure class:list={['figure', { 'figure--wide': wide }]}>
  <div class="figure-frame">
    <slot />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin-block: 2.2em;
  }
  .figure-frame {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elev);
    padding: clamp(0.75rem, 2vw, 1.25rem);
    overflow: hidden;
  }
  @media (min-width: 1100px) {
    .figure--wide {
      width: min(58rem, 92vw);
      margin-inline: calc(50% - min(29rem, 46vw));
    }
  }
</style>
