---
interface Props {
  caption?: string;
  /** make an interactive figure span even wider than the default break-out */
  wide?: boolean;
}
const { caption, wide = false } = Astro.props;
---

<figure class:list={['figure', { 'figure--wide': wide }]}>
  <div class="figure-frame">
    <slot />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin-block: 2.2em;
  }
  .figure-frame {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elev);
    padding: clamp(0.75rem, 2vw, 1.25rem);
    overflow: hidden;
  }
  /* Break figures out of the reading column and centre them on the viewport.
     Works because the prose column is itself viewport-centred. */
  @media (min-width: 1000px) {
    .figure {
      width: min(54rem, 92vw);
      margin-left: 50%;
      transform: translateX(-50%);
    }
    .figure--wide {
      width: min(66rem, 94vw);
    }
  }
</style>
