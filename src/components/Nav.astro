---
import { Icon } from 'astro-icon/components';
import ThemeFontControls from './ThemeFontControls.astro';
import Logo from './Logo.astro';
import { profile } from '../data/profile';

const links = [
  { href: '/about', label: 'About', icon: 'lucide:user-round' },
  { href: '/publications', label: 'Publications', icon: 'lucide:book-text' },
  { href: '/blog', label: 'Writing', icon: 'lucide:pen-line' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header class="nav" data-scrolled="false">
  <div class="nav-inner container">
    <a href="/" class="nav-brand" aria-label={`${profile.name} — home`}>
      <Logo size={32} />
      <span class="nav-name">{profile.name}</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="nav-icon"
            title={l.label}
            aria-label={l.label}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            <Icon name={l.icon} aria-hidden="true" />
          </a>
        ))
      }
      <ThemeFontControls />
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: transparent;
    transition: background-color 0.25s ease, border-color 0.25s ease,
      backdrop-filter 0.25s ease;
    border-bottom: 1px solid transparent;
  }
  .nav[data-scrolled='true'] {
    background: var(--bg-glass);
    backdrop-filter: saturate(160%) blur(12px);
    -webkit-backdrop-filter: saturate(160%) blur(12px);
    border-bottom-color: var(--border);
  }
  .nav-inner {
    height: var(--nav-h);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--fg);
    text-decoration: none;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-right: auto;
  }
  .nav-name {
    font-size: 1.02rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .nav-icon {
    display: inline-grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    color: var(--fg-muted);
    font-size: 1.15rem;
    text-decoration: none;
    transition: color 0.16s ease, background-color 0.16s ease;
  }
  .nav-icon:hover {
    color: var(--accent);
    background: var(--bg-sunken);
  }
  .nav-icon[aria-current='page'] {
    color: var(--accent);
  }

  @media (max-width: 460px) {
    .nav-name {
      display: none;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('.nav');
  const onScroll = () => {
    if (header) header.dataset.scrolled = String(window.scrollY > 8);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
